{
  "name": "InterCopy-figma-plugin",
  "version": "1.0.0",
  "description": "InterCopy Figma plugin — push/pull design component text layers to the InterCopy platform",
  "private": true,
  "scripts": {
    "build": "npm run build:main && npm run build:ui && npm run build:html",
    "build:main": "esbuild src/main.ts --bundle --outfile=dist/main.js --target=es2017 --format=iife",
    "build:ui": "esbuild src/ui.ts --bundle --outfile=dist/ui.js --target=es2017 --format=iife",
    "build:html": "node scripts/build-ui-html.js",
    "watch": "concurrently \"npm run watch:main\" \"npm run watch:ui\"",
    "watch:main": "esbuild src/main.ts --bundle --outfile=dist/main.js --target=es2017 --format=iife --watch",
    "watch:ui": "esbuild src/ui.ts --bundle --outfile=dist/ui.js --target=es2017 --format=iife --watch",
    "dev": "npm run build && npm run watch"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@figma/plugin-typings": "^1.98.0",
    "esbuild": "^0.25.0",
    "concurrently": "^8.2.0"
  }
}

